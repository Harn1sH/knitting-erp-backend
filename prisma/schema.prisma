// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // No url or directUrl here!
}

model ChallanCounter {
  id         String @id @default(cuid())
  type       String   // "DC" or "GRN"
  year       Int
  lastNumber Int

  @@unique([type, year])
}

model DeliveryChallan {
  id          String   @id @default(uuid())
  dcNo        String   @unique
  jobCardId   String
  vehicle     String?
  companyName String?
  date        DateTime
  createdAt   DateTime @default(now())

  jobCard     JobCard        @relation(fields: [jobCardId], references: [id])
  items       DeliveryItem[]
}

model DeliveryItem {
  id              String   @id @default(uuid())
  challanId       String
  fabricItemId    String
  quantityKg      Float
  numberOfRolls   Int?
  weightPerRoll   Float?
  fabricName      String?
  rolls           Int
  wtPerRoll       Float

  challan         DeliveryChallan @relation(fields: [challanId], references: [id])
  fabricItem      FabricItem      @relation(fields: [fabricItemId], references: [id])
}

model YarnInwardChallan {
  id          String   @id @default(uuid())
  grnNo       String   @unique
  jobCardId   String
  supplierId  String
  entryDate   DateTime
  remarks     String?
  createdAt   DateTime @default(now())

  jobCard     JobCard            @relation(fields: [jobCardId], references: [id])
  supplier    Supplier           @relation(fields: [supplierId], references: [id])
  items       YarnInwardItem[]
}

model YarnInwardItem {
  id           String   @id @default(uuid())
  challanId    String
  fabricItemId String
  supplierId   String?
  yarnName     String
  color        String?
  bags         Int
  cones        Int
  netWeight    Float
  weightPerBag Float
  wtPerCone    Float?

  challan      YarnInwardChallan @relation(fields: [challanId], references: [id])
  fabricItem   FabricItem        @relation(fields: [fabricItemId], references: [id])
  supplier     Supplier?         @relation(fields: [supplierId], references: [id])
}

model JobCard {
  id              String   @id @default(uuid())
  jobNumber       String   @unique
  customerName    String
  deliveryDate    DateTime
  status          String
  remarks         String
  createdAt       DateTime @default(now())

  brand           String
  machine         String
  machineNote     String

  fabricItems         FabricItem[]

  yarnInwardChallans  YarnInwardChallan[]
  productions         Production[]
  deliveryChallans    DeliveryChallan[]
}

model Production {
  id          String   @id @default(uuid())
  jobCardId   String
  operatorId  String?   // 👈 add this
  machine     String
  kgProduced  Float
  hoursRun    Float
  stoppage    String?
  date        DateTime
  jobCard     JobCard  @relation(fields: [jobCardId], references: [id])
  operator    User?    @relation(fields: [operatorId], references: [id]) // 👈 THIS FIXES IT
}


enum Role {
  ADMIN
  EMPLOYEE
}

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  role        Role
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  productions Production[]
}

model JobCardCounter {
  year       Int @id
  lastNumber Int @default(0)
}

model Supplier {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  phoneNumber   String?
  altPhoneNumber String?
  email         String?
  address       String?
  city          String?
  state         String?
  pincode       String?

  gstNumber     String?  @unique
  panNumber     String?
  bankName      String?
  accountNumber String?
  ifscCode      String?

  remarks       String?

  paymentTerms  String?  // e.g., "30 days", "Advance"

  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  yarnInwardChallans  YarnInwardChallan[]
  yarnInwardItems     YarnInwardItem[]
}

model Client {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  phoneNumber   String?
  altPhoneNumber String?
  email         String?
  address       String?
  city          String?
  state         String?
  pincode       String?

  gstNumber     String?  @unique
  panNumber     String?
  bankName      String?
  accountNumber String?
  ifscCode      String?

  remarks       String?

  paymentTerms  String?  // e.g., "30 days", "Advance"

  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MasterEntry {
  id          String   @id @default(cuid())
  category    String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([category, name])
}

model FabricItem {
  id             String   @id @default(cuid())
  jobCardId      String
  jobCard        JobCard  @relation(fields: [jobCardId], references: [id])
  gsm            String
  dia            String
  count          String
  composition    String
  quality        String
  mill           String
  rate           Float
  orderQuantity  Float
  totalYarnNeeded Float
  createdAt      DateTime @default(now())

  yarnInwardItems  YarnInwardItem[]
  deliveryItems    DeliveryItem[]
}